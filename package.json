{
  "name": "whatsapp-otomasyon",
  "version": "0.1.2",
  "description": "wppconnect tabanlı, toplu mesaj/kampanya, otomasyon ve CRM özellikli WhatsApp masaüstü uygulaması",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k -n NEXT,ESBUILD,ELECTRON -c blue,yellow,green \"npm:dev:next\" \"npm:dev:esbuild\" \"npm:dev:electron\"",
    "dev:next": "next dev -p 3000",
    "dev:esbuild": "node scripts/build-electron.mjs --watch",
    "dev:electron": "wait-on tcp:3000 && nodemon --watch dist-electron --delay 300ms --exec \"electron .\"",
    "build": "next build && npm run build:electron && node scripts/prepare-resources.mjs && node scripts/download-chrome.mjs",
    "build:electron": "node scripts/build-electron.mjs",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "release:mac": "npm run build && electron-builder --mac --publish always",
    "release:win": "npm run build && electron-builder --win --publish always",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate && electron-builder install-app-deps",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@puppeteer/browsers": "^2.13.2",
    "@tanstack/react-query": "^5.101.2",
    "@wppconnect-team/wppconnect": "^2.2.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "libphonenumber-js": "^1.13.8",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "p-queue": "^9.3.1",
    "prisma": "^7.8.0",
    "puppeteer-core": "^24.43.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "typescript-eslint": "^8.64.0",
    "wait-on": "^9.0.10"
  }
}
